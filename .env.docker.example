# Local audit defaults. On the VPS keep the bind IP local to Nginx and use port 3003.
MAKKA_BIND_IP=127.0.0.1
MAKKA_PORT=3000
MAKKA_TAG=local

# Visitor counter database. Generate distinct, long values before public deployment.
MAKKA_DB_NAME=makka_hotel
MAKKA_DB_USER=makka
MAKKA_DB_PASSWORD=replace-with-a-long-random-password
VISITOR_IP_HASH_SECRET=replace-with-a-long-random-secret
# Looks up a city only for new unique IP hashes. Use {ip} as the placeholder.
VISITOR_GEOLOOKUP_URL=https://ipwho.is/{ip}
# Leave empty to use the curated Indonesia and Uzbekistan major-city list.
VISITOR_MAJOR_CITIES=
